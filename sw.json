// Roomie Service Worker — enables PWA install + offline shell
const CACHE = 'roomie-v1';
const SHELL = [
  '/home.html', '/login.html', '/signup.html', '/setup.html',
  '/profile.html', '/roommate.html', '/messages.html',
  '/style.css', '/firebase.js', '/upload.js', '/manifest.json'
];

self.addEventListener('install', e => {
  e.waitUntil(
    caches.open(CACHE).then(c => c.addAll(SHELL)).then(() => self.skipWaiting())
  );
});

self.addEventListener('activate', e => {
  e.waitUntil(
    caches.keys().then(keys =>
      Promise.all(keys.filter(k => k !== CACHE).map(k => caches.delete(k)))
    ).then(() => self.clients.claim())
  );
});

self.addEventListener('fetch', e => {
  // Network first — fall back to cache for shell files
  e.respondWith(
    fetch(e.request).catch(() => caches.match(e.request))
  );
});

